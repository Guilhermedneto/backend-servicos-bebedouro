# URLs (4000 = servidor SSR `node dist/...`; 4200 = `npm start` dev server)
FRONTEND_URL=http://localhost:4000
CORS_ORIGINS=http://localhost:4000,http://127.0.0.1:4000,http://localhost:4200,http://127.0.0.1:4200

# Azure OpenAI — busca com IA (LangChain/LangGraph).
# Enquanto vazios, o endpoint /api/search/ai responde 503 e o site usa a busca textual comum.
# AZURE_OPENAI_ENDPOINT=https://SEU-RECURSO.openai.azure.com/
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_DEPLOYMENT=gpt-5-mini
# AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Admin (seed criado no startup; sem ADMIN_PASSWORD o seed é ignorado)
ADMIN_EMAIL=admin@servicosbebedouro.com.br
ADMIN_PASSWORD=defina-uma-senha-forte-aqui
ADMIN_NAME=Administrador
